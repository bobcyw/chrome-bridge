{
  "manifest_version": 3,
  "name": "Chrome Bridge",
  "version": "1.0.0",
  "description": "Browser automation bridge for AI agents — WebSocket commands, CSP bypass, trusted typing",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "debugger",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["csp-bypass.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Chrome Bridge"
  }
}
